generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id                 String    @id @default(uuid())
  title              String
  description        String?
  status             String    @default("inbox")
  priority           String    @default("normal")
  assignedAgentId    String?   @map("assigned_agent_id")
  workflowTemplateId String?   @map("workflow_template_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  dueDate            DateTime? @map("due_date")
  workspaceId        String?   @map("workspace_id")
  deliverables       String    @default("[]")
  sessionKey         String?   @map("session_key")
  parentTaskId       String?   @map("parent_task_id")
  clientId           String?   @map("client_id")

  activities Activity[]
  client     Client?   @relation(fields: [clientId], references: [id])

  @@map("tasks")
}

model Agent {
  id          String   @id
  name        String
  role        String
  description String?
  soulMd      String?  @map("soul_md")
  model       String?
  status      String   @default("standby")
  workspaceId String?  @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  activities Activity[]

  @@map("agents")
}

model WorkflowTemplate {
  id          String  @id
  name        String
  description String?
  stages      String
  workspaceId String? @map("workspace_id")

  @@map("workflow_templates")
}

model Activity {
  id           String   @id @default(uuid())
  taskId       String?  @map("task_id")
  agentId      String?  @map("agent_id")
  activityType String   @map("activity_type")
  content      String?
  createdAt    DateTime @default(now()) @map("created_at")

  task  Task?  @relation(fields: [taskId], references: [id])
  agent Agent? @relation(fields: [agentId], references: [id])

  @@map("activities")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

// ==========================================
// CRM & Client Management Models
// ==========================================

model Package {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  services    String   // JSON array of service types included
  isCustom    Boolean  @default(false) @map("is_custom")
  createdAt   DateTime @default(now()) @map("created_at")

  clients Client[]

  @@map("packages")
}

model ServiceTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  billingType String   @map("billing_type")
  category    String
  features    String
  isPopular   Boolean  @default(false) @map("is_popular")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("service_templates")
}

model Client {
  id             String    @id @default(uuid())
  businessName   String    @map("business_name")
  contactName    String?   @map("contact_name")
  email          String?
  phone          String?
  businessType   String?   @map("business_type")
  city           String?
  state          String?
  slug           String?   @unique
  status           String    @default("lead")
  statusChangedAt  DateTime  @default(now()) @map("status_changed_at")
  monthlyRevenue   Float?    @map("monthly_revenue")
  dateAcquired   DateTime? @map("date_acquired")
  tags           String?   // JSON array
  packageId      String?   @map("package_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // Lead enrichment fields (populated by lead-gen-auto)
  ownerName          String?  @map("owner_name")
  googleReviewCount  Int?     @map("google_review_count")
  hasFacebook        Boolean? @map("has_facebook")
  hasInstagram       Boolean? @map("has_instagram")
  lastWebsiteUpdate  String?  @map("last_website_update")
  mobileFriendly     Boolean? @map("mobile_friendly")
  hasOnlineBooking   Boolean? @map("has_online_booking")

  package              Package?              @relation(fields: [packageId], references: [id])
  notes                ClientNote[]
  websites             Website[]
  services             Service[]
  links                ClientLink[]
  tasks                Task[]
  proposals            Proposal[]
  reports              Report[]
  changeRequests       ChangeRequest[]
  magicLinks           ClientMagicLink[]
  portalSessions       ClientPortalSession[]
  leadSubmissions      LeadSubmission[]
  healthSnapshots      HealthSnapshot[]
  gbpConnection        GbpConnection?
  gbpSnapshots         GbpSnapshot[]

  // Client portal feature config
  leadWebhookKey       String?  @unique @map("lead_webhook_key")
  gbpPlaceId           String?  @map("gbp_place_id")
  googleReviewUrl      String?  @map("google_review_url")

  // Onboarding tracking
  onboardingEmailSentAt DateTime? @map("onboarding_email_sent_at")

  @@map("clients")
}

// ==========================================
// Client Portal: Website Health
// ==========================================

model HealthSnapshot {
  id                 String   @id @default(uuid())
  clientId           String   @map("client_id")
  url                String
  uptime             Boolean?
  httpStatus         Int?     @map("http_status")
  responseTimeMs     Int?     @map("response_time_ms")
  pagespeedMobile    Int?     @map("pagespeed_mobile")
  pagespeedDesktop   Int?     @map("pagespeed_desktop")
  lcpMs              Int?     @map("lcp_ms")
  clsScore           Float?   @map("cls_score")
  inpMs              Int?     @map("inp_ms")
  sslValid           Boolean? @map("ssl_valid")
  sslExpiresAt       DateTime? @map("ssl_expires_at")
  sslIssuer          String?  @map("ssl_issuer")
  netlifyState       String?  @map("netlify_state")
  netlifyDeployedAt  DateTime? @map("netlify_deployed_at")
  raw                String?  // JSON — full API responses for debugging
  createdAt          DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("health_snapshots")
}

// ==========================================
// Client Portal: Lead Tracking
// ==========================================

model LeadSubmission {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  name       String?
  email      String?
  phone      String?
  subject    String?
  message    String?
  source     String?  // form name, URL, or "unknown"
  pageUrl    String?  @map("page_url")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  meta       String?  // JSON — extra fields
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("lead_submissions")
}

// ==========================================
// Client Portal: Google Business Profile
// ==========================================

model GbpConnection {
  id            String   @id @default(uuid())
  clientId      String   @unique @map("client_id")
  accountId     String?  @map("account_id")
  locationId    String?  @map("location_id")
  locationName  String?  @map("location_name")
  accessToken   String   @map("access_token")
  refreshToken  String   @map("refresh_token")
  expiresAt     DateTime @map("expires_at")
  scope         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("gbp_connections")
}

model GbpSnapshot {
  id              String   @id @default(uuid())
  clientId        String   @map("client_id")
  rating          Float?
  reviewCount     Int?     @map("review_count")
  newReviewsMonth Int?     @map("new_reviews_month")
  recentReviews   String?  @map("recent_reviews") // JSON array
  raw             String?
  createdAt       DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("gbp_snapshots")
}

model ClientNote {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_notes")
}

model Website {
  id                 String    @id @default(uuid())
  clientId           String    @map("client_id")
  url                String
  status             String    @default("development")
  hostingProvider    String?   @map("hosting_provider")
  domainRegistrar    String?   @map("domain_registrar")
  domainExpiration   DateTime? @map("domain_expiration")
  sslStatus          String?   @map("ssl_status")
  cmsPlatform        String?   @map("cms_platform")
  launchDate         DateTime? @map("launch_date")
  lastUpdated        DateTime? @map("last_updated")
  gaConnected        Boolean   @default(false) @map("ga_connected")
  gaPropertyId       String?   @map("ga_property_id")
  gscConnected       Boolean   @default(false) @map("gsc_connected")
  maintenancePlan    Boolean   @default(false) @map("maintenance_plan")
  maintenanceDetails String?   @map("maintenance_details")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  netlifySiteId       String?   @map("netlify_site_id")
  githubRepoUrl       String?   @map("github_repo_url")
  screenshotUrl       String?   @map("screenshot_url")
  screenshotUpdatedAt DateTime? @map("screenshot_updated_at")

  client       Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  seoPages     SeoPage[]
  crawlHistory CrawlHistory[]

  @@map("websites")
}

model SeoPage {
  id               String    @id @default(uuid())
  websiteId        String    @map("website_id")
  pageUrl          String    @map("page_url")
  pageTitle        String?   @map("page_title")
  titleLength      Int?      @map("title_length")
  metaDescription  String?   @map("meta_description")
  metaDescLength   Int?      @map("meta_desc_length")
  metaKeywords     String?   @map("meta_keywords")
  canonicalUrl     String?   @map("canonical_url")
  language         String?   @map("language")
  h1Tag            String?   @map("h1_tag")
  h1Count          Int?      @map("h1_count")
  headingStructure String?   @map("heading_structure")
  imagesTotal      Int?      @map("images_total")
  imagesWithAlt    Int?      @map("images_with_alt")
  internalLinks    Int?      @map("internal_links")
  externalLinks    Int?      @map("external_links")
  wordCount        Int?      @map("word_count")
  paragraphCount   Int?      @map("paragraph_count")
  targetKeyword    String?   @map("target_keyword")
  keywordDensity   Float?    @map("keyword_density")
  hasViewport      Boolean   @default(false) @map("has_viewport")
  hasFavicon       Boolean   @default(false) @map("has_favicon")
  hasOgTags        Boolean   @default(false) @map("has_og_tags")
  hasTwitterTags   Boolean   @default(false) @map("has_twitter_tags")
  hasCharset       Boolean   @default(false) @map("has_charset")
  hasDoctype       Boolean   @default(false) @map("has_doctype")
  isHttps          Boolean   @default(false) @map("is_https")
  responseTime     Int?      @map("response_time")
  htmlSize         Int?      @map("html_size")
  statusCode       Int?      @map("status_code")
  crawlData        String?   @map("crawl_data")
  seoScore         Int?      @map("seo_score")
  metaScore        Int?      @map("meta_score")
  qualityScore     Int?      @map("quality_score")
  structureScore   Int?      @map("structure_score")
  linkScore        Int?      @map("link_score")
  serverScore      Int?      @map("server_score")
  issues           String?   @map("issues")
  lastAudited      DateTime? @map("last_audited")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  website Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  changes SeoChange[]

  @@index([websiteId])
  @@map("seo_pages")
}

model SeoChange {
  id           String   @id @default(uuid())
  seoPageId    String   @map("seo_page_id")
  fieldChanged String?  @map("field_changed")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  changedBy    String?  @map("changed_by")
  createdAt    DateTime @default(now()) @map("created_at")

  seoPage SeoPage @relation(fields: [seoPageId], references: [id], onDelete: Cascade)

  @@map("seo_changes")
}

model Service {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  serviceType     String    @map("service_type")
  status          String    @default("active")
  billingType     String?   @map("billing_type")
  price           Float?
  startDate       DateTime? @map("start_date")
  nextBillingDate DateTime? @map("next_billing_date")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("services")
}

model ClientLink {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  category  String?
  label     String
  url       String?
  username  String?
  password  String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_links")
}

// ==========================================
// Revenue Features Models
// ==========================================

model ProspectorSearch {
  id            String   @id @default(uuid())
  area          String
  businessTypes String   @map("business_types") // JSON array
  count         Int
  resultsCount  Int      @map("results_count")
  leadsAdded    Int      @default(0) @map("leads_added")
  results       String   // JSON — full results data
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("prospector_searches")
}

model Proposal {
  id              String    @id @default(uuid())
  proposalNumber  String?   @unique @map("proposal_number")
  clientId        String    @map("client_id")
  packageId       String?   @map("package_id")
  packageName     String?   @map("package_name")
  packagePrice    Float?    @map("package_price")
  addons          String?   // JSON array of { name, price }
  discount        Float?    // percentage
  totalOneTime    Float?    @map("total_one_time")
  totalMonthly    Float?    @map("total_monthly")
  content         String    // JSON — all generated sections
  pdfUrl          String?   @map("pdf_url")
  customPrice     Float?    @map("custom_price")
  status          String    @default("draft") // draft, sent, accepted, declined, expired
  validUntil      DateTime? @map("valid_until")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("proposals")
}

model Report {
  id        String    @id @default(uuid())
  clientId  String    @map("client_id")
  month     Int
  year      Int
  content   String    // JSON — all generated sections
  pdfUrl    String?   @map("pdf_url")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model CrawlHistory {
  id          String   @id @default(uuid())
  websiteId   String   @map("website_id")
  pagesFound  Int      @map("pages_found")
  issuesFound Int      @default(0) @map("issues_found")
  crawledAt   DateTime @default(now()) @map("crawled_at")

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("crawl_history")
}

// ==========================================
// Change Request System
// ==========================================

model ClientMagicLink {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_magic_links")
}

model ClientPortalSession {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_portal_sessions")
}

model ChangeRequest {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  changeType      String    @map("change_type")
  pageLocation    String    @map("page_location")
  details         String
  priority        String    @default("normal")
  status          String    @default("new")
  files           String?   // JSON array of file URLs
  generatedPrompt String?   @map("generated_prompt")
  internalNotes   String?   @map("internal_notes")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  completedAt     DateTime? @map("completed_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("change_requests")
}

// ==========================================
// API Key System
// ==========================================

model ApiKey {
  id         String    @id @default(uuid())
  key        String    @unique @default(uuid())
  label      String
  active     Boolean   @default(true)
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

// ==========================================
// Notification System
// ==========================================

model Notification {
  id        String   @id @default(uuid())
  type      String   // "audit_submission", extensible later
  title     String
  message   String
  read      Boolean  @default(false)
  leadId    String?  @map("lead_id")
  actionUrl String?  @map("action_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read, createdAt])
  @@map("notifications")
}

// ==========================================
// Free Website Audit System
// ==========================================

model AuditSubmission {
  id           String   @id @default(uuid())
  name         String
  email        String
  businessName String   @map("business_name")
  websiteUrl   String   @map("website_url")
  results      String?  // JSON — full audit results
  emailSubject String?  @map("email_subject")
  emailBody    String?  @map("email_body")
  leadId       String?  @map("lead_id")
  status       String   @default("pending") // pending, completed, emailed
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("audit_submissions")
}
